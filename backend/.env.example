# Copy to .env and adjust for your machine.

ENV=development

# Postgres (matches database/docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg2://alphasource:alphasource@localhost:5432/alphasource

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Gemini -- required for GitHub's semantic embedding match
# (app/integrations/github/intelligence/semantic_matcher.py). No longer
# required for Query Understanding (see QUERY_PROVIDER below), but still
# needed if the GitHub connector is configured.
GEMINI_API_KEY=

# Groq -- default Query Understanding provider (Sprint 29). Free tier:
# 1,000 requests/day on Llama 3.3 70B, no card required. Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=

# Which LLM provider Query Understanding uses by default ("groq" or
# "gemini"). Falls back to FALLBACK_PROVIDER if the primary's API key
# isn't set.
QUERY_PROVIDER=groq
FALLBACK_PROVIDER=gemini

# --- Sprint 30: candidate persistence + minimal recruiter identity ---
# "memory" (default) keeps today's behavior -- in-process, JSON-seeded,
# wiped on restart. Set to "postgres" once DATABASE_URL points at a real,
# migrated database to persist candidates across restarts/redeploys.
CANDIDATE_REPOSITORY_BACKEND=memory

# If set (and CANDIDATE_REPOSITORY_BACKEND=postgres), a recruiter account
# with this username/password is created automatically on startup if none
# exists yet.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# How long an issued login session stays valid.
SESSION_TTL_HOURS=168

# Whether protected endpoints (POST /api/search/smart,
# /integrations/*/configure) require a valid session token. Defaults to
# false so local dev/tests with no Postgres keep working unchanged.
REQUIRE_AUTH=false

# --- Sprint 32: persistent, encrypted connector credentials (GitHub PAT) ---
# "memory" (default) keeps today's behavior -- the GitHub PAT lives only
# in this process's memory and is wiped on every restart/redeploy, so
# POST /integrations/github/configure must be re-sent after each deploy.
# Set to "postgres" to persist it (encrypted) across restarts instead.
CONNECTOR_CREDENTIALS_BACKEND=memory

# Required only when CONNECTOR_CREDENTIALS_BACKEND=postgres. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Never commit a real value of this to source control.
APP_ENCRYPTION_KEY=
