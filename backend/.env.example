# Copy to .env and adjust for your machine.

ENV=development

# Postgres (matches database/docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg2://alphasource:alphasource@localhost:5432/alphasource

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Gemini -- required for GitHub's semantic embedding match
# (app/integrations/github/intelligence/semantic_matcher.py). No longer
# required for Query Understanding (see QUERY_PROVIDER below), but still
# needed if the GitHub connector is configured.
GEMINI_API_KEY=

# Groq -- default Query Understanding provider (Sprint 29). Free tier:
# 1,000 requests/day on Llama 3.3 70B, no card required. Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=

# Which LLM provider Query Understanding uses by default ("groq" or
# "gemini"). Falls back to FALLBACK_PROVIDER if the primary's API key
# isn't set.
QUERY_PROVIDER=groq
FALLBACK_PROVIDER=gemini
